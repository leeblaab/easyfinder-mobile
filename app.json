{
  "expo": {
    "name": "EasyFinder UAE",
    "slug": "easyfinder-uae",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#176B87"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ae.easyfinder.app",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses the camera to upload vendor logos.",
        "NSPhotoLibraryUsageDescription": "This app accesses your photo library to upload vendor logos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#176B87"
      },
      "package": "ae.easyfinder.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow EasyFinder to access your photos for uploading vendor logos."
        }
      ],
      "expo-font"
    ],
    "scheme": "easyfinder"
  }
}
